# Database
DATABASE_URL=postgresql://user:password@localhost:5432/replysequence

# Redis
REDIS_URL=redis://localhost:6379

# Zoom OAuth (Server-to-Server)
ZOOM_ACCOUNT_ID=your_account_id
ZOOM_CLIENT_ID=your_client_id
ZOOM_CLIENT_SECRET=your_client_secret

# Zoom Webhook Secret Token (from Zoom App > Feature > Webhook)
ZOOM_WEBHOOK_SECRET_TOKEN=your_webhook_secret_token

# Microsoft Teams / Graph API (App Registration)
MICROSOFT_TEAMS_TENANT_ID=your_tenant_id
MICROSOFT_TEAMS_CLIENT_ID=your_client_id
MICROSOFT_TEAMS_CLIENT_SECRET=your_client_secret
MICROSOFT_TEAMS_WEBHOOK_SECRET=your_webhook_secret

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend Email
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=ReplySequence <noreply@yourdomain.com>
RESEND_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phx_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_TEAM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# App URL (used for OAuth redirects, Stripe, email links, etc.)
# Production: https://www.replysequence.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry Error Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Typefully (auto-retweet cron)
TYPEFULLY_API_KEY=your_typefully_api_key

# Node Environment
NODE_ENV=development
